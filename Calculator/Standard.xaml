<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Calculator.Standard"
             Title="Standard"
             BackgroundColor="#F2F5F7">

    <ContentPage.Resources>

        <Style TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="TextColor" Value="Black"/>
            <Setter Property="FontSize" Value="25"/>
        </Style>

        <Style TargetType="Button" x:Key="Lt">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="TextColor" Value="Black"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>

    </ContentPage.Resources>

    <Grid RowDefinitions="auto, 2*, *, *, *, *, *, *, *" ColumnDefinitions="*, *, *, *" Margin="5">
        <Label x:Name="History" Text="" HorizontalTextAlignment="End" FontSize="Large" Margin="5" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4"/>
        <Entry x:Name="Screen" Text="0" HorizontalTextAlignment="End" FontSize="48" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Keyboard="Numeric"/>
        <Grid ColumnDefinitions="*,*,*,*,*,*" Grid.Row="2" Grid.ColumnSpan="4">
            <Button Grid.Column="0" Text="MC" Style="{StaticResource Lt}" Clicked="Memory_Clicked"/>
            <Button Grid.Column="1" Text="MR" Style="{StaticResource Lt}" Clicked="Memory_Clicked"/>
            <Button Grid.Column="2" Text="M+" Style="{StaticResource Lt}" Clicked="Memory_Clicked"/>
            <Button Grid.Column="3" Text="M-" Style="{StaticResource Lt}" Clicked="Memory_Clicked"/>
            <Button Grid.Column="4" Text="MS" Style="{StaticResource Lt}" Clicked="Memory_Clicked"/>
            <Button Grid.Column="5" Text="Mv" Style="{StaticResource Lt}" Clicked="Memory_Clicked"/>
        </Grid>

        <Button Grid.Row="3" Grid.Column="0" Text="%" Clicked="UnaryOperator_Clicked"/>
        <Button Grid.Row="3" Grid.Column="1" Text="CE" Clicked="ClearEntry_Clicked"/>
        <Button Grid.Row="3" Grid.Column="2" Text="C" Clicked="Clear_Clicked"/>
        <Button Grid.Row="3" Grid.Column="3" Text="←" Clicked="BackSpaceClicked"/>

        <Button Grid.Row="4" Grid.Column="0" Text="1/x" Clicked="UnaryOperator_Clicked"/>
        <Button Grid.Row="4" Grid.Column="1" Text="x²" Clicked="UnaryOperator_Clicked"/>
        <Button Grid.Row="4" Grid.Column="2" Text="²√x" Clicked="UnaryOperator_Clicked"/>
        <Button Grid.Row="4" Grid.Column="3" Text="÷" Clicked="OperatorClicked"/>

        <Button Grid.Row="5" Grid.Column="0" Text="7" Clicked="NumClicked"/>
        <Button Grid.Row="5" Grid.Column="1" Text="8" Clicked="NumClicked"/>
        <Button Grid.Row="5" Grid.Column="2" Text="9" Clicked="NumClicked"/>
        <Button Grid.Row="5" Grid.Column="3" Text="×" Clicked="OperatorClicked"/>

        <Button Grid.Row="6" Grid.Column="0" Text="4" Clicked="NumClicked"/>
        <Button Grid.Row="6" Grid.Column="1" Text="5" Clicked="NumClicked"/>
        <Button Grid.Row="6" Grid.Column="2" Text="6" Clicked="NumClicked"/>
        <Button Grid.Row="6" Grid.Column="3" Text="-" Clicked="OperatorClicked" />

        <Button Grid.Row="7" Grid.Column="0" Text="1" Clicked="NumClicked"/>
        <Button Grid.Row="7" Grid.Column="1" Text="2" Clicked="NumClicked"/>
        <Button Grid.Row="7" Grid.Column="2" Text="3" Clicked="NumClicked"/>
        <Button Grid.Row="7" Grid.Column="3" Text="+" Clicked="OperatorClicked"/>

        <Button Grid.Row="8" Grid.Column="0" Text="+/−" Clicked="PlusMinus_Clicked"/>
        <Button Grid.Row="8" Grid.Column="1" Text="0" Clicked="NumClicked"/>
        <Button Grid.Row="8" Grid.Column="2" Text="," Clicked="Decimal_Clicked"/>
        <Button Grid.Row="8" Grid.Column="3" Text="=" Clicked="EqualClicked" Background="#1B66A1" TextColor="White" FontSize="30"/>
    </Grid>
</ContentPage>